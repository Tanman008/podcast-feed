generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector(schema: "extensions")]
}

model Source {
  id                 String         @id @default(uuid())
  name               String
  slug               String         @unique
  sourceType         SourceType
  platform           String
  url                String
  description        String?
  imageUrl           String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  minDurationSeconds Int?
  maxDurationSeconds Int?
  checkIntervalHours Int            @default(1)
  lastCheckedAt      DateTime?
  following          Boolean        @default(true)
  feedUrl            String?
  searchQuery        String?
  episodes           Episode[]
  ingestionJobs      IngestionJob[]

  @@index([sourceType])
  @@index([platform])
  @@map("Source")
}

model Episode {
  id               String            @id @default(uuid())
  sourceId         String
  externalId       String
  title            String
  description      String?
  publishedAt      DateTime?
  durationSeconds  Int?
  thumbnailUrl     String?
  transcriptStatus TranscriptStatus  @default(pending)
  rawTranscript    String?
  errorMessage     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  source           Source            @relation(fields: [sourceId], references: [id])
  interestMatches  InterestMatch[]
  chunks           TranscriptChunk[]

  @@unique([sourceId, externalId])
  @@index([sourceId])
  @@index([publishedAt])
  @@index([transcriptStatus])
  @@map("Episode")
}

model Speaker {
  id             String            @id @default(uuid())
  name           String
  normalizedName String            @unique
  bio            String?
  imageUrl       String?
  metadataJson   Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  chunks         TranscriptChunk[]

  @@index([normalizedName])
  @@map("Speaker")
}

model TranscriptChunk {
  id                String                   @id @default(uuid())
  episodeId         String
  speakerId         String?
  chunkIndex        Int
  text              String
  cleanedText       String
  summary           String?
  startTimeSeconds  Float
  endTimeSeconds    Float
  tokenCount        Int
  embedding         Unsupported("vector")?
  importanceScore   Float?
  noveltyScore      Float?
  convictionScore   Float?
  relevanceScore    Float?
  sentimentScore    Float?
  metadataJson      Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  keyQuote          String?
  keyPhrase         String?
  searchVector      Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, COALESCE(text, ''::text))"))
  speakerLabel      String?
  speakerName       String?
  claimUnit         String?
  claimCompleteness Float?
  claimAllParts     Boolean?
  chunkType         String?
  entities          ChunkEntity[]
  claims            Claim[]
  interestMatches   InterestMatch[]
  episode           Episode                  @relation(fields: [episodeId], references: [id])
  speaker           Speaker?                 @relation(fields: [speakerId], references: [id])

  @@index([episodeId])
  @@index([speakerId])
  @@index([chunkIndex])
  @@index([importanceScore])
  @@index([noveltyScore])
  @@index([convictionScore])
  @@index([createdAt])
  @@index([embedding], map: "transcript_chunk_embedding_idx")
  @@index([searchVector], type: Gin)
  @@map("TranscriptChunk")
}

model Claim {
  id                 String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  chunkId            String
  highlight          String
  startSentenceIndex Int             @default(0)
  endSentenceIndex   Int             @default(0)
  primarySubject     String?
  mentionedEntities  String[]        @default([])
  claimType          String
  specificity        Float
  completeness       Float
  gloss              String?
  context            String?
  createdAt          DateTime        @default(now())
  numbers            String[]        @default([])
  chunk              TranscriptChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  interestMatches    InterestMatch[]

  @@index([chunkId])
  @@index([claimType])
  @@index([completeness])
  @@map("Claim")
}

model Entity {
  id             String        @id @default(uuid())
  entityType     EntityType
  name           String
  normalizedName String
  ticker         String?
  description    String?
  metadataJson   Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  chunks         ChunkEntity[]
  feedItems      FeedEntity[]

  @@unique([normalizedName, entityType])
  @@index([entityType])
  @@index([ticker])
  @@map("Entity")
}

model ChunkEntity {
  id          String          @id @default(uuid())
  chunkId     String
  entityId    String
  confidence  Float
  mentionType MentionType     @default(direct)
  createdAt   DateTime        @default(now())
  chunk       TranscriptChunk @relation(fields: [chunkId], references: [id])
  entity      Entity          @relation(fields: [entityId], references: [id])

  @@unique([chunkId, entityId])
  @@index([chunkId])
  @@index([entityId])
  @@index([confidence])
  @@map("ChunkEntity")
}

model IngestionJob {
  id           String    @id @default(uuid())
  episodeUrl   String
  sourceId     String
  episodeId    String?
  status       JobStatus @default(queued)
  progress     Int       @default(0)
  chunksTotal  Int?
  chunksDone   Int?
  errorMessage String?
  attempts     Int       @default(0)
  createdAt    DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  source       Source    @relation(fields: [sourceId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@map("IngestionJob")
}

model UserInterest {
  id        String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String          @default("default")
  term      String
  createdAt DateTime        @default(now())
  matches   InterestMatch[]

  @@index([userId])
  @@map("UserInterest")
}

model InterestMatch {
  id           String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  interestId   String
  episodeId    String
  chunkId      String
  score        Float
  createdAt    DateTime        @default(now())
  quality      String?
  claimId      String?
  entityWeight Float           @default(1.0)
  chunk        TranscriptChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  claim        Claim?          @relation(fields: [claimId], references: [id], onDelete: Cascade)
  episode      Episode         @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  interest     UserInterest    @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@unique([interestId, claimId])
  @@index([interestId])
  @@index([episodeId])
  @@index([score])
  @@index([createdAt])
  @@map("InterestMatch")
}

model Feed {
  id          String       @id @default(uuid())
  userId      String?
  name        String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  entities    FeedEntity[]

  @@index([userId])
  @@map("Feed")
}

model FeedEntity {
  id        String   @id @default(uuid())
  feedId    String
  entityId  String
  weight    Float    @default(1.0)
  createdAt DateTime @default(now())
  entity    Entity   @relation(fields: [entityId], references: [id])
  feed      Feed     @relation(fields: [feedId], references: [id])

  @@unique([feedId, entityId])
  @@index([feedId])
  @@index([entityId])
  @@map("FeedEntity")
}

enum SourceType {
  youtube
  spotify
  apple_podcast
  earnings_call
  x_space
  interview
  conference
  podcast
  search
}

enum EntityType {
  ticker
  company
  person
  investor
  executive
  topic
  product
  sector
  fund
}

enum MentionType {
  direct
  implied
  contextual
}

enum TranscriptStatus {
  pending
  processing
  completed
  failed
}

enum JobStatus {
  queued
  running
  completed
  failed
}
