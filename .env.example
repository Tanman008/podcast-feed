# Database — Supabase direct connection (port 5432)
# Get from: Supabase Dashboard → Settings → Database → Connection String → URI
# IMPORTANT: Prisma CLI reads .env, not .env.local. Put DATABASE_URL in both files.
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# OpenAI (embeddings — text-embedding-3-small; entity extraction — GPT-4o-mini)
OPENAI_API_KEY="sk-..."

# Deepgram (audio transcription + speaker diarization — Nova-2)
DEEPGRAM_API_KEY="your-deepgram-api-key"

# yt-dlp cookie auth — required locally to bypass YouTube bot detection
# Values: chrome, safari, firefox, brave, chromium
YTDLP_COOKIES_BROWSER=chrome

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
