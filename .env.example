# Database — Supabase direct connection (port 5432)
# Get from: Supabase Dashboard → Settings → Database → Connection String → URI
# IMPORTANT: Prisma CLI reads .env, not .env.local. Put DATABASE_URL in both files.
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# OpenAI (embeddings — text-embedding-3-small; entity extraction — GPT-4o-mini)
OPENAI_API_KEY="sk-..."

# Deepgram (audio transcription + speaker diarization — Nova-2)
DEEPGRAM_API_KEY="your-deepgram-api-key"

# Podcast Index API — free at podcastindex.org/developer
# Required for: following channels by name or PI URL, secondary episode discovery.
# Without keys: RSS URL follows still work; name-based search falls back to iTunes-only.
# If your secret contains $ signs, store it base64-encoded as PODCAST_INDEX_API_SECRET_B64.
PODCAST_INDEX_API_KEY="your-pi-api-key"
PODCAST_INDEX_API_SECRET="your-pi-api-secret"
# PODCAST_INDEX_API_SECRET_B64="base64-encoded-secret"  # use if secret contains $ signs

# yt-dlp cookie auth — required locally to bypass YouTube bot detection
# Values: chrome, safari, firefox, brave, chromium
YTDLP_COOKIES_BROWSER=chrome

# OpenAI concurrency — tune to your account tier to avoid 429s.
# OPENAI_MAX_CONCURRENCY: hard process-wide cap on simultaneous OpenAI requests.
#   Tier 1 (~500 RPM): 8   Tier 2 (~5k RPM): 16   Tier 3+: 24
# LLM_CONCURRENCY: per-episode parallelism inside analyzeChunksBatch.
#   Should be ≤ OPENAI_MAX_CONCURRENCY. 6 leaves headroom for embeddings + matching.
OPENAI_MAX_CONCURRENCY=8
LLM_CONCURRENCY=6

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
